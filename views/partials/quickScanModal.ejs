<div class="modal fade" id="quickScanModal" tabindex="-1" aria-labelledby="quickScanModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title fs-5" id="quickScanModalLabel">Quickscan</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label for="quickScanCameraSelect" class="form-label">Kamera</label>
          <div class="quickscan-camera-controls">
            <select id="quickScanCameraSelect" class="form-select form-select-sm">
              <option value="">Kamera wird geladen …</option>
            </select>
            <button id="quickScanTorchToggle" type="button" class="btn btn-outline-secondary btn-sm d-none" aria-pressed="false">Licht aus</button>
          </div>
        </div>
        <div id="quickScanReaderWrap" class="quickscan-reader-wrap mb-3" aria-label="Barcode Scanner Vorschau">
          <div id="quickScanReader"></div>
          <div id="quickScanFeedback" class="quickscan-feedback" aria-hidden="true"></div>
        </div>
        <div id="quickScanStatus" class="small text-muted mb-3">Kamera wird initialisiert …</div>
        <div class="input-group mb-3">
          <input id="quickScanManualInput" type="text" class="form-control" placeholder="Code manuell eingeben">
          <button id="quickScanManualAdd" type="button" class="btn btn-outline-secondary">Hinzufügen</button>
        </div>
        <div class="border rounded p-2">
          <div class="small text-muted mb-2">Gescannt</div>
          <ul id="quickScanLog" class="list-group list-group-flush small"></ul>
        </div>
      </div>
      <div class="modal-footer">
        <button id="quickScanCloseButton" type="button" class="btn btn-secondary" data-bs-dismiss="modal">Schließen</button>
      </div>
    </div>
  </div>
</div>
